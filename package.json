{
  "name": "fd-mate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "concurrently -k -n emu,web -c blue,green \"npm run emu\" \"vite\"",
    "dev:preview": "PORT=3001 vite",
    "emu": "JAVA_HOME=/opt/homebrew/opt/openjdk@25 PATH=/opt/homebrew/opt/openjdk@25/bin:$PATH npx -y firebase-tools@latest emulators:start --only auth,database --project vue-demo-5e240",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite build && vite preview",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src test vite.config.ts vitest.config.ts eslint.config.mjs --ext .ts,.tsx,.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
